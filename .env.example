# Flask secret key for session security
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
APP_ENV=development
# Only enable behind a trusted reverse proxy that rewrites client IP headers.
TRUST_PROXY_HEADERS=false

# Shared local development backend endpoint
# Both backend (web.py) and frontend Vite proxy can read these values.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080

# Supabase backend (required when running: python web.py --backend supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM Council via Cloudflare AI Gateway (Unified Billing) ─────────────
#
# 3 expert models + Gemini Flash moderator, all routed through a single
# CF AI Gateway compat endpoint. Credits are drawn from the Cloudflare
# account associated with CF_AIG_TOKEN — no per-provider keys are needed.
# Load credits at: https://dash.cloudflare.com/?to=/:account/ai/ai-gateway

# CF AI Gateway Unified token (cfut_*). Auth header: cf-aig-authorization.
CF_AIG_TOKEN=

# CF AI Gateway compat endpoint (defaults to the immi-council gateway).
LLM_COUNCIL_CF_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/30ffcfbf8c4103048bc38a5398b7ec99/immi-council/compat/chat/completions

# LLM Council model routing — provider prefix REQUIRED on compat endpoint:
#   openai/<model>             → OpenAI (gpt-5 family auto-handled in code)
#   anthropic/<model>          → Anthropic
#   google-ai-studio/<model>   → Google AI Studio (Gemini family)
LLM_COUNCIL_OPENAI_MODEL=openai/gpt-5-mini-2025-08-07
LLM_COUNCIL_GEMINI_PRO_MODEL=google-ai-studio/gemini-3.1-pro-preview
LLM_COUNCIL_ANTHROPIC_MODEL=anthropic/claude-sonnet-4-6
LLM_COUNCIL_GEMINI_FLASH_MODEL=google-ai-studio/gemini-2.5-flash

# LLM Council limits — defaults sized for reasoning models. Probe data:
# gemini-2.5-pro at 2400 returned completion=0; 4096 is reliability/cost
# sweet spot. 8192 reserved for moderator (14-field JSON output).
LLM_COUNCIL_MAX_OUTPUT_TOKENS=4096
LLM_COUNCIL_MODERATOR_MAX_TOKENS=8192
LLM_COUNCIL_TIMEOUT_SECONDS=120

# LLM Council system prompts (optional overrides)
LLM_COUNCIL_SYSTEM_PROMPT_OPENAI=
LLM_COUNCIL_SYSTEM_PROMPT_GEMINI_PRO=
LLM_COUNCIL_SYSTEM_PROMPT_ANTHROPIC=
LLM_COUNCIL_SYSTEM_PROMPT_MODERATOR=

# Telegram bot username for the login widget (no @ prefix)
VITE_TELEGRAM_BOT_NAME=immi_case_bot

# JWT secrets (Wrangler secrets for Worker; also needed by Flask)
# Set via: wrangler secret put JWT_SECRET_CURRENT
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_CURRENT=
JWT_SECRET_PREVIOUS=
JWT_KID_CURRENT=v1
JWT_KID_PREVIOUS=v0
