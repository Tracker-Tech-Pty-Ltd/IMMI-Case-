# Flask secret key for session security
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# LLM Council provider API keys
OPENAI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY can be used instead of GEMINI_API_KEY
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# LLM Council model routing
LLM_COUNCIL_OPENAI_MODEL=chatgpt-5.2
LLM_COUNCIL_GEMINI_PRO_MODEL=gemini-3.0-pro
LLM_COUNCIL_ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_COUNCIL_GEMINI_FLASH_MODEL=gemini-3.0-flash

# LLM Council reasoning and limits
LLM_COUNCIL_OPENAI_REASONING=medium
LLM_COUNCIL_GEMINI_THINKING_BUDGET=1024
LLM_COUNCIL_ANTHROPIC_THINKING_BUDGET=4096
LLM_COUNCIL_MAX_OUTPUT_TOKENS=1600
LLM_COUNCIL_TIMEOUT_SECONDS=70

# Anthropic API compatibility
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_WEB_SEARCH_BETA=web-search-2025-03-05

# LLM Council system prompts (optional overrides)
LLM_COUNCIL_SYSTEM_PROMPT_OPENAI=
LLM_COUNCIL_SYSTEM_PROMPT_GEMINI_PRO=
LLM_COUNCIL_SYSTEM_PROMPT_ANTHROPIC=
LLM_COUNCIL_SYSTEM_PROMPT_MODERATOR=
